# Скопируйте в .env.deploy в корне репозитория на сервере:
#   cp deploy.env.example .env.deploy
# Заполните секреты (длинные случайные строки для JWT и надёжный пароль БД).

POSTGRES_PASSWORD=change_me_strong_db_password

JWT_ACCESS_SECRET=change_me_long_random_access_secret
JWT_REFRESH_SECRET=change_me_long_random_refresh_secret

# Базовый URL API для сборки фронта (относительный путь — для одного домена billbo.ru):
VITE_API_BASE_URL=/api

# Опционально, если нужны карты в проде:
# VITE_YANDEX_MAPS_API_KEY=
